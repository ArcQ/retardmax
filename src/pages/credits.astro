---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CreditStore from '@/components/CreditStore';
import { db } from '@/lib/db/db';
import { subscriptions, users } from '@/lib/db/schema';
import { CREDIT_PACKS, MONTHLY_MAX_PLAN } from '@/lib/pricing';
import { grantDueDailyCredits } from '@/lib/credits';
import { getEnv } from '@/lib/env';
import { eq } from 'drizzle-orm';
if (!Astro.locals.user) return Astro.redirect('/api/auth/login?next=/credits');
const env = getEnv(Astro.locals); await grantDueDailyCredits(env.DB, Astro.locals.user.id);
const wallet = await db(env.DB).select({ credits: users.postCredits }).from(users).where(eq(users.id, Astro.locals.user.id)).get();
const sub = await db(env.DB).select().from(subscriptions).where(eq(subscriptions.userId, Astro.locals.user.id)).get();
const loaded = Astro.url.searchParams.has('loaded'); const subscribed = Astro.url.searchParams.has('subscribed');
---
<BaseLayout title="Load Up — RETARDMAX"><section class="space-y-8"><div><p class="eyebrow">Your ammo</p><h1 class="font-display text-6xl">LOAD.<br /><span class="text-flame">UP.</span></h1><p class="mt-3 text-lg font-bold text-white/60">Public moves cost one credit. Buy a stack, then spend them when the move is real.</p></div>{(loaded || subscribed) && <p class="rounded-xl border border-green-500/30 bg-green-500/10 p-3 font-bold text-green-300">Loaded. The board is waiting.</p>}<div class="card flex items-center justify-between p-5"><div><p class="eyebrow">Post credits</p><p class="font-display text-5xl text-flame">{wallet?.credits ?? 0}</p></div><div class="max-w-xs text-right text-sm font-bold text-white/55">{sub?.status === 'active' ? <><p>DAILY MAX is active — one new credit lands every day.</p><form class="mt-2" method="POST" action="/api/checkout/manage-subscription"><button class="text-xs font-black text-flame hover:text-white">Manage or cancel subscription →</button></form></> : 'No subscription running. Packs never expire.'}</div></div><CreditStore client:load packs={Object.values(CREDIT_PACKS)} monthlyAmountCents={MONTHLY_MAX_PLAN.amountCents} /></section></BaseLayout>
