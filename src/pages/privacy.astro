import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Privacy — RETARDMAX" description="How RETARDMAX handles accounts, posts, groups, and payments."><section class="space-y-6"><h1 class="font-display text-6xl">PRIVACY.</h1><p class="text-white/50">Effective July 18, 2026.</p><div class="card space-y-5 p-5 text-white/70"><h2 class="font-display text-3xl text-white">What we collect</h2><p>RETARDMAX collects account identifiers, handles, avatars, posts, votes, groups, streaks, reports, and payment-related records needed to run the board. We also receive basic security and error logs.</p><h2 class="font-display text-3xl text-white">How we use it</h2><p>We use information to authenticate users, publish the boards you choose to make public, moderate abuse, maintain streaks, process purchases through Stripe, and improve reliability. We do not sell personal information.</p><h2 class="font-display text-3xl text-white">Your choices</h2><p>You can edit your profile, keep posts private where offered, and ask for access or deletion at <a class="text-flame" href="mailto:privacy@retardmax.app">privacy@retardmax.app</a>. Public posts may remain in backups or moderation records for a reasonable period.</p></div></section></BaseLayout>
