---
import BaseLayout from '@/layouts/BaseLayout.astro'; import { db } from '@/lib/db/db'; import { users } from '@/lib/db/schema'; import { eq } from 'drizzle-orm';
import { getEnv } from '@/lib/env';
if (!Astro.locals.user) return Astro.redirect('/api/auth/login?next=/settings');
if (Astro.request.method === 'POST' && Astro.locals.user) { const form = await Astro.request.formData(); const handle = String(form.get('handle') ?? '').toLowerCase(); const xHandle = String(form.get('x_handle') ?? '').replace(/^@/, '').trim() || null; if (/^[a-z0-9_]{2,24}$/.test(handle)) { await db(getEnv(Astro.locals).DB).update(users).set({ handle, xHandle }).where(eq(users.id, Astro.locals.user.id)); } return Astro.redirect('/settings?saved=1'); }
const saved = Astro.url.searchParams.get('saved');
---
<BaseLayout title="Settings — RETARDMAX"><section class="mx-auto max-w-xl space-y-6"><div><p class="eyebrow">Identity</p><h1 class="font-display text-6xl">SETTINGS.</h1></div>{saved && <p class="rounded-xl border border-green-500/30 bg-green-500/10 p-3 text-sm font-bold text-green-300">Saved.</p>}<form method="POST" class="card space-y-5 p-5"><label class="block space-y-2"><span class="text-sm font-black uppercase text-white/50">Handle</span><input required pattern="[a-zA-Z0-9_]{2,24}" name="handle" value={Astro.locals.user.handle} class="field" /></label><label class="block space-y-2"><span class="text-sm font-black uppercase text-white/50">X handle (optional)</span><input name="x_handle" value={Astro.locals.user.xHandle ?? ''} placeholder="yourhandle" class="field" /></label><button class="btn-flame">Save identity</button></form><form method="POST" action="/api/auth/logout"><button class="btn-quiet">Log out</button></form></section></BaseLayout>
