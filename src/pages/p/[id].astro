---
import BaseLayout from '@/layouts/BaseLayout.astro'; import PostCard from '@/components/PostCard.astro'; import PayButton from '@/components/PayButton'; import { feedPosts } from '@/lib/data';
import { getEnv } from '@/lib/env';
const id = Astro.params.id!; const env = getEnv(Astro.locals); const [rendered] = await feedPosts(env.DB, { postId: id, userId: Astro.locals.user?.id, limit: 1 }); if (!rendered || (rendered.visibility === 'private' && Astro.locals.user?.id !== rendered.authorId)) return Astro.redirect('/404');
const canPublish = Astro.locals.user?.id === rendered.authorId && rendered.visibility === 'private' && rendered.postedOn === new Date().toISOString().slice(0, 10); const og = `${env.SITE_URL.replace(/\/$/, '')}/api/og/${id}.png`;
---
<BaseLayout title={`${rendered.body.slice(0, 60)} — RETARDMAX`} description={`${rendered.body} — @${rendered.handle}`}><Fragment slot="head"><meta property="og:image" content={og} /><meta name="twitter:image" content={og} /></Fragment><section class="space-y-5"><a href="/" class="text-sm font-black text-white/45 hover:text-white">← Back to the board</a><PostCard post={rendered} user={Astro.locals.user} />{canPublish && <div class="card space-y-3 border-flame/30 p-5"><p class="eyebrow">Unlock the board</p><p class="font-display text-3xl">MAKE IT PUBLIC.</p><p class="text-sm text-white/55">A dollar supports the site, gates the bots, and puts your move in front of the board.</p><PayButton client:load postId={id} /></div>}</section></BaseLayout>
