---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Composer from '@/components/Composer';
import PostCard from '@/components/PostCard.astro';
import { topToday, feedPosts, userGroups } from '@/lib/data';
import { getEnv } from '@/lib/env';
const env = getEnv(Astro.locals); const user = Astro.locals.user; const today = await topToday(env.DB, user?.id); const fresh = (await feedPosts(env.DB, { date: new Date().toISOString().slice(0, 10), publicOnly: true, userId: user?.id, limit: 30 })).filter((p) => !today.some((t) => t.id === p.id)); const groups = user ? await userGroups(env.DB, user.id) : [];
---
<BaseLayout title="Today’s Picks — RETARDMAX"><section class="space-y-10">{user ? <div class="space-y-6"><div class="space-y-3"><p class="eyebrow">{new Date().toISOString().slice(0, 10)} · UTC</p><h1 class="font-display text-6xl leading-[0.9] sm:text-8xl">TODAY’S<br /><span class="text-flame">PICKS.</span></h1><p class="max-w-lg text-lg font-bold text-white/55">One bold move. One receipt. The board is watching.</p></div><Composer client:load groups={groups} /></div> : <div class="relative overflow-hidden rounded-2xl border border-flame/30 bg-flame/[0.06] p-6 shadow-2xl shadow-black/40 sm:p-10"><p class="eyebrow">Daily · one bold move · public board</p><h1 class="mt-3 font-display text-6xl leading-[0.85] sm:text-8xl">MAKE ONE<br />BOLD MOVE.<br /><span class="text-flame">PROVE IT.</span></h1><p class="mt-5 max-w-lg text-lg font-bold text-white/60">Log your boldest move of the day. Rack up Ws. Keep the 🔥 streak alive. The board never lies.</p><div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center"><a class="btn-flame px-6 py-3 text-base" href="/api/auth/login">Sign in with Google</a><span class="text-sm font-bold text-white/45">Two clicks. No email. Free to start.</span></div><div class="mt-9 grid gap-px overflow-hidden rounded-xl border border-white/10 bg-white/10 sm:grid-cols-3"><div class="bg-ink/80 p-4"><p class="font-display text-2xl text-flame">POST DAILY</p><p class="mt-1 text-sm font-bold text-white/55">One move a day. Miss it, streak dies.</p></div><div class="bg-ink/80 p-4"><p class="font-display text-2xl text-flame">LOAD UP</p><p class="mt-1 text-sm font-bold text-white/55">4 posts for $3. Cheaper when you stack.</p></div><div class="bg-ink/80 p-4"><p class="font-display text-2xl text-flame">EARN YOUR Ws</p><p class="mt-1 text-sm font-bold text-white/55">Top 10 daily. Legends all-time.</p></div></div></div>}<div class="space-y-4"><div class="flex items-end justify-between gap-3"><div><p class="eyebrow">Editorial leaderboard</p><h2 class="font-display text-4xl sm:text-5xl">TODAY’S TOP 10</h2></div><span class="shrink-0 text-sm font-bold text-white/40">Ws + boosts × 5</span></div>{today.length ? today.map((post, i) => <PostCard post={post} user={user} rank={i + 1} />) : <div class="card p-8 text-center text-lg font-bold text-white/50">Board’s empty. Somebody’s about to be first on the wall.</div>}</div>{fresh.length > 0 && <div class="space-y-4"><h2 class="font-display text-4xl sm:text-5xl">FRESH TODAY</h2>{fresh.map((post) => <PostCard post={post} user={user} />)}</div>}</section></BaseLayout>
