---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Composer from '@/components/Composer';
import PostCard from '@/components/PostCard.astro';
import { topToday, feedPosts, userGroups } from '@/lib/data';
import { getEnv } from '@/lib/env';
const env = getEnv(Astro.locals); const user = Astro.locals.user; const today = await topToday(env.DB, user?.id); const fresh = (await feedPosts(env.DB, { date: new Date().toISOString().slice(0, 10), publicOnly: true, userId: user?.id, limit: 30 })).filter((p) => !today.some((t) => t.id === p.id)); const groups = user ? await userGroups(env.DB, user.id) : [];
---
<BaseLayout title="Today’s Picks — RETARDMAX"><section class="space-y-8"><div class="space-y-3"><p class="eyebrow">{new Date().toISOString().slice(0, 10)} · UTC</p><h1 class="font-display text-6xl leading-none sm:text-8xl">TODAY’S<br /><span class="text-flame">PICKS.</span></h1><p class="max-w-lg text-lg font-bold text-white/55">One bold move. One receipt. The board is watching.</p></div>{user ? <Composer client:load groups={groups} /> : <div class="card flex flex-wrap items-center justify-between gap-4 border-flame/40 bg-flame/10 p-5"><div><p class="font-display text-3xl">WHAT DID YOU DO?</p><p class="text-white/60">Sign in to log your move and start a streak.</p></div><a class="btn-flame" href="/api/auth/login">Sign in with Google</a></div>}<div class="space-y-4"><div class="flex items-end justify-between"><div><p class="eyebrow">Editorial leaderboard</p><h2 class="font-display text-4xl">TOP 10</h2></div><span class="text-sm font-bold text-white/40">Ws + boosts × 5</span></div>{today.length ? today.map((post, i) => <PostCard post={post} user={user} rank={i + 1} />) : <div class="card p-8 text-center text-white/50">No public moves yet. Be the first one on the wall.</div>}</div>{fresh.length > 0 && <div class="space-y-4"><h2 class="font-display text-4xl">FRESH TODAY</h2>{fresh.map((post) => <PostCard post={post} user={user} />)}</div>}</section></BaseLayout>
