---
import BaseLayout from '@/layouts/BaseLayout.astro'; import { eq } from 'drizzle-orm'; import { db } from '@/lib/db/db'; import { pins, reports, users } from '@/lib/db/schema'; import { feedPosts } from '@/lib/data';
import { getEnv } from '@/lib/env';
const env = getEnv(Astro.locals); const list = (env.ADMIN_EMAILS ?? '').split(',').map((x) => x.trim().toLowerCase()); if (!Astro.locals.user || !list.includes(Astro.locals.user.email.toLowerCase())) return Astro.redirect('/'); const today = new Date().toISOString().slice(0, 10); const publicPosts = await feedPosts(env.DB, { date: today, publicOnly: true, limit: 50 }); const todayPins = await db(env.DB).select().from(pins).where(eq(pins.pinnedOn, today)).all(); const queue = await db(env.DB).select({ id: reports.id, reason: reports.reason, postId: reports.postId, reporter: users.handle }).from(reports).innerJoin(users, eq(reports.reporterUserId, users.id)).where(eq(reports.resolved, false)).all();
---
<BaseLayout title="Admin — RETARDMAX"><section class="space-y-8"><div><p class="eyebrow">Back office</p><h1 class="font-display text-6xl">ADMIN.</h1></div><section class="space-y-3"><h2 class="font-display text-4xl">TODAY’S PINS ({todayPins.length}/3)</h2>{publicPosts.map((post) => <div class="card flex items-center justify-between gap-3 p-4"><span class="min-w-0 truncate font-bold">{post.body}</span><form action="/api/admin" method="POST"><input type="hidden" name="post_id" value={post.id} /><input type="hidden" name="action" value={todayPins.some((p) => p.postId === post.id) ? 'unpin' : 'pin'} /><button class={todayPins.some((p) => p.postId === post.id) ? 'btn-quiet' : 'btn-flame'}>{todayPins.some((p) => p.postId === post.id) ? 'Unpin' : 'Pin'}</button></form></div>)}</section><section class="space-y-3"><h2 class="font-display text-4xl">REPORTS ({queue.length})</h2>{queue.map((report) => <div class="card space-y-3 p-4"><p class="font-bold">{report.reason} <span class="text-white/40">· @{report.reporter}</span></p><div class="flex flex-wrap gap-2"><form action="/api/admin" method="POST"><input type="hidden" name="action" value="delete" /><input type="hidden" name="post_id" value={report.postId} /><button class="btn-flame">Delete post</button></form><form action="/api/admin" method="POST"><input type="hidden" name="action" value="ban" /><input type="hidden" name="report_id" value={report.id} /><button class="btn-quiet">Ban author</button></form><form action="/api/admin" method="POST"><input type="hidden" name="action" value="dismiss" /><input type="hidden" name="report_id" value={report.id} /><button class="btn-quiet">Dismiss</button></form></div></div>)}</section></section></BaseLayout>
