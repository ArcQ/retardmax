---
import '../styles/global.css';
import { getEnv } from '@/lib/env';
const { title = 'Retardmax — make a bold move', description = 'One bold move a day. Keep receipts.' } = Astro.props;
const user = Astro.locals.user;
const env = getEnv(Astro.locals);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0e12" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="canonical" href={new URL(Astro.url.pathname, env?.SITE_URL ?? Astro.url.origin).href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="RETARDMAX" />
    <meta property="og:url" content={new URL(Astro.url.pathname, env?.SITE_URL ?? Astro.url.origin).href} />
    <meta property="og:image" content={new URL('/og.svg', env?.SITE_URL ?? Astro.url.origin).href} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og.svg', env?.SITE_URL ?? Astro.url.origin).href} />
    <slot name="head" />
  </head>
  <body class="poster-grid min-h-screen">
    <header class="sticky top-0 z-20 border-b border-white/10 bg-ink/90 backdrop-blur">
      <nav class="mx-auto flex max-w-3xl items-center justify-between gap-3 px-4 py-4">
        <a href="/" class="font-display text-2xl tracking-tight text-white">RETARD<span class="text-flame">MAX</span></a>
        <div class="hidden items-center gap-4 text-sm font-bold text-white/65 sm:flex">
          <a href="/" class="hover:text-white">Today</a><a href="/all-time" class="hover:text-white">All-Time</a><a href="/g" class="hover:text-white">Groups</a><a href="/log" class="hover:text-white">My Log</a><a href="/credits" class="text-flame hover:text-white">Load Up</a>
        </div>
        {user ? <a href="/settings" class="flex items-center gap-2 text-sm font-bold"><img src={user.avatarUrl ?? 'https://api.dicebear.com/9.x/initials/svg?seed=' + user.handle} alt="" class="h-8 w-8 rounded-full border border-white/20" /><span class="hidden sm:inline">@{user.handle}</span></a> : <a href="/api/auth/login" class="btn-flame px-3 py-2 text-sm">Sign in</a>}
      </nav>
      <div class="flex items-center gap-5 overflow-x-auto px-4 pb-3 text-sm font-bold text-white/65 sm:hidden">
        <a href="/" class="shrink-0 hover:text-white">Today</a><a href="/all-time" class="shrink-0 hover:text-white">All-Time</a><a href="/g" class="shrink-0 hover:text-white">Groups</a><a href="/log" class="shrink-0 hover:text-white">My Log</a><a href="/credits" class="shrink-0 text-flame hover:text-white">Load Up</a>
      </div>
    </header>
    <main class="mx-auto w-full max-w-3xl px-4 pb-16 pt-8"><slot /></main>
    <footer class="mx-auto max-w-3xl border-t border-white/10 px-4 py-10 text-center"><p class="font-display text-2xl tracking-tight text-white/70">RETARD<span class="text-flame">MAX</span></p><p class="mx-auto mt-3 max-w-md text-xs leading-5 text-white/40">Retardmaxxing is about YOUR bold moves. Doxxing, harassment, targeting people = deleted + banned.</p><p class="mt-4 text-xs font-bold text-white/40"><a class="hover:text-white" href="/privacy">Privacy</a> · <a class="hover:text-white" href="/terms">Terms</a></p></footer>
    {env?.SITE_URL && <script is:inline define:vars={{ siteUrl: env.SITE_URL }}>window.__RMX_SITE_URL__ = siteUrl;</script>}
  </body>
</html>
