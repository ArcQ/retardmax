---
import '../styles/global.css';
import { getEnv } from '@/lib/env';
const { title = 'Retardmax — make a bold move', description = 'One bold move a day. Keep receipts.' } = Astro.props;
const user = Astro.locals.user;
const env = getEnv(Astro.locals);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="RETARDMAX" />
    <meta name="twitter:card" content="summary_large_image" />
    <slot name="head" />
  </head>
  <body class="poster-grid min-h-screen">
    <header class="sticky top-0 z-20 border-b border-white/10 bg-ink/90 backdrop-blur">
      <nav class="mx-auto flex max-w-3xl items-center justify-between gap-3 px-4 py-4">
        <a href="/" class="font-display text-2xl tracking-tight text-white">RETARD<span class="text-flame">MAX</span></a>
        <div class="hidden items-center gap-4 text-sm font-bold text-white/65 sm:flex">
          <a href="/" class="hover:text-white">Today</a><a href="/all-time" class="hover:text-white">All-Time</a><a href="/g" class="hover:text-white">Groups</a><a href="/log" class="hover:text-white">My Log</a>
        </div>
        {user ? <a href="/settings" class="flex items-center gap-2 text-sm font-bold"><img src={user.avatarUrl ?? 'https://api.dicebear.com/9.x/initials/svg?seed=' + user.handle} alt="" class="h-8 w-8 rounded-full border border-white/20" /><span class="hidden sm:inline">@{user.handle}</span></a> : <a href="/api/auth/login" class="btn-flame px-3 py-2 text-sm">Sign in</a>}
      </nav>
    </header>
    <main class="mx-auto w-full max-w-3xl px-4 pb-16 pt-8"><slot /></main>
    <footer class="mx-auto max-w-3xl border-t border-white/10 px-4 py-8 text-center text-xs leading-5 text-white/40">Retardmaxxing is about YOUR bold moves. Doxxing, harassment, targeting people = deleted + banned.</footer>
    {env?.SITE_URL && <script is:inline define:vars={{ siteUrl: env.SITE_URL }}>window.__RMX_SITE_URL__ = siteUrl;</script>}
    <script is:inline>
      if (window.location.hostname !== 'localhost' && window.location.hostname !== '127.0.0.1' && import.meta.env.PUBLIC_POSTHOG_KEY) {
        const s = document.createElement('script'); s.src = 'https://cdn.posthog.com/posthog.js'; s.async = true; document.head.appendChild(s);
      }
    </script>
  </body>
</html>
